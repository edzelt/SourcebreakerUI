**/.qmlls.ini

# qtcreator generated files
*.pro.user*
*.qbs.user*
CMakeLists.txt.user*

# xemacs temporary files
*.flc

# Vim temporary files
.*.swp

# Visual Studio generated files
*.ib_pdb_index
*.idb
*.ilk
*.pdb
*.sln
*.suo
*.vcproj
*vcproj.*.*.user
*.ncb
*.sdf
*.opensdf
*.vcxproj
*vcxproj.*

# MinGW generated files
*.Debug
*.Release

# Python byte code
*.pyc

# Binaries
# --------
*.dll
*.exe

# Directories with generated files
.moc/
.obj/
.pch/
.rcc/
.uic/
/build*/
/.qtcreator/
/DBTables/

# --- Дополнения для вашего проекта ---

# Кэш языкового сервера (Clangd), который Qt Creator создает для подсказок
/.qtc_clangd/
.clangd/

# Внутренние файлы CMake (иногда создаются вне папки build)
/.cmake/

# Базы данных SQLite (ваш индекс кода)
# Если вы хотите хранить пустую базу в репозитории, не добавляйте это.
# Но обычно локальную БД с результатами парсинга в git не кладут.
*.sqlite
*.db

# Файлы логов
*.log

# Папка вывода VS Code или Visual Studio (если решите открыть проект там)
/out/
/.vs/

# Если будете использовать clang-format для форматирования кода
.clang-format
